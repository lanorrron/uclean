generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  role             Role
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now()) @updatedAt
  deleted_at       DateTime?
  first_name       String?
  last_name        String?
  assigned_reports Report[]         @relation("Report_assignee")
  invitations      UserInvitation[] @relation("Invitation_creator")
}

model Report {
  id                 String       @id @default(uuid())
  description        String?
  latitude           Float
  longitude          Float
  status             ReportStatus @default(PENDING)
  assigned_to_id     String?
  created_at         DateTime     @default(now())
  incident_type      String
  register_number    String
  user_type          String
  deleted_at         DateTime?
  updated_at         DateTime     @default(now()) @updatedAt
  area               Area
  report_image_url   String?
  resolved_at        DateTime?
  resolved_image_url String?
  assigned_to        User?        @relation("Report_assignee", fields: [assigned_to_id], references: [id])
}

model UserInvitation {
  id          String           @id @default(uuid())
  email       String           @unique
  role        Role
  createdById String?
  status      InvitationStatus @default(PENDING)
  created_at  DateTime         @default(now())
  deleted_at  DateTime?
  updated_at  DateTime         @updatedAt
  createdBy   User?            @relation("Invitation_creator", fields: [createdById], references: [id])
}

enum Role {
  ADMIN
  MAINTENANCE
  CLEANING
  SECURITY
}

enum ReportStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}
enum Area {
  CLEANING
  MAINTENANCE
  SECURITY
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum UserType {
  STUDENT
  TEACHER
  ADMIN
  VISITOR
}

enum IncidentType {
  WASTE
  BATHROOM
  LIGHTING
  FURNITURE
  SECURITY
  OTHER
}
